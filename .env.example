# ============================================================
# Environment Variables — copy these into Vercel dashboard
# Settings → Environment Variables
# ============================================================

# Database (PostgreSQL — e.g. Neon, Supabase, Railway)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Better Auth
BETTER_AUTH_SECRET="replace-with-a-long-random-secret-min-32-chars"
BETTER_AUTH_URL="https://your-app.vercel.app"

# Fine configuration (in currency units per day)
FINE_PER_DAY=2
LOAN_PERIOD_DAYS=14
MAX_RENEWALS=2
MAX_BOOKS_PER_USER=5
